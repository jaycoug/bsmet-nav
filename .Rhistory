library(readr)
library(dplyr)
tennis1_raw <- read_csv("TENNIS1.DAT.txt")
names(tennis1_raw) <- gsub("'", "", names(tennis1_raw))
cat("Variables:", paste(names(tennis1_raw), collapse = ", "), "\n")
cat("Rows:", nrow(tennis1_raw), "\n")
names(tennis1_raw) <- gsub("'", "", names(tennis1_raw))
tennis1 <- tennis1_raw %>%
mutate(
Age = ifelse(Age == 99, NA, Age),
across(everything(), ~ifelse(. == 9, NA, .)),
Mat_curr = ifelse(Mat_curr %in% c(6, 7), NA, Mat_curr)
)
# Create binary outcome: case = 1+ episodes, control = 0 episodes
tennis1 <- tennis1 %>%
mutate(case = ifelse(!is.na(Num_epis) & Num_epis >= 1, 1,
ifelse(!is.na(Num_epis) & Num_epis == 0, 0, NA)))
# Listwise deletion on model variables
tennis1_clean <- tennis1 %>%
select(case, Age, Sex, Typ_curr, Wgt_curr, Mat_curr, Str_curr) %>%
na.omit()
View(tennis1_clean)
names(tennis1_raw) <- gsub("'", "", names(tennis1_raw))
tennis1 <- tennis1_raw %>%
mutate(
Age = ifelse(Age == 99, NA, Age),
across(everything(), ~ifelse(. == 9, NA, .)),
Mat_curr = ifelse(Mat_curr %in% c(6, 7), NA, Mat_curr)
)
# Binary recode, case: >1 episodes, control: 0 episodes.
tennis1 <- tennis1 %>%
mutate(case = ifelse(!is.na(Num_epis) & Num_epis >= 1, 1,
ifelse(!is.na(Num_epis) & Num_epis == 0, 0, NA)))
tennis1_clean <- tennis1 %>%
select(case, Age, Sex, Typ_curr, Wgt_curr, Mat_curr, Str_curr) %>%
na.omit()
names(tennis1_raw) <- gsub("'", "", names(tennis1_raw))
tennis1 <- tennis1_raw %>%
mutate(
Age = ifelse(Age == 99, NA, Age),
across(everything(), ~ifelse(. == 9, NA, .)),
Mat_curr = ifelse(Mat_curr %in% c(6, 7), NA, Mat_curr)
)
# Binary recode, case: >1 episodes, control: 0 episodes.
tennis1 <- tennis1 %>%
mutate(case = ifelse(!is.na(Num_epis) & Num_epis >= 1, 1,
ifelse(!is.na(Num_epis) & Num_epis == 0, 0, NA)))
tennis1_clean <- tennis1 %>%
select(case, Age, Sex, Typ_curr, Wgt_curr, Mat_curr, Str_curr) %>%
na.omit()
# # Set variables as factors
tennis1_clean <- tennis1_clean %>%
mutate(
Sex      = factor(Sex),
Typ_curr = factor(Typ_curr),
Wgt_curr = factor(Wgt_curr),
Mat_curr = factor(Mat_curr),
Str_curr = factor(Str_curr)
)
nrow(tennis1_clean)
model <- glm(case ~ Age + Sex + Typ_curr + Wgt_curr + Mat_curr + Str_curr,
family = binomial(link = "logit"),
data = tennis1_clean)
summary(model)
coef_tbl <- summary(model)$coefficients
for (nm in rownames(coef_tbl)[-1]) {
sig <- ifelse(coef_tbl[nm, 4] < 0.001, "***",
ifelse(coef_tbl[nm, 4] < 0.01,  "**",
ifelse(coef_tbl[nm, 4] < 0.05,  "*", "NS")))
cat(sprintf("%-15s  beta = %8.4f  SE = %8.4f  z = %7.3f  p = %.4f  %s\n",
nm, coef_tbl[nm, 1], coef_tbl[nm, 2], coef_tbl[nm, 3], coef_tbl[nm, 4], sig))
}
beta_sex <- coef(model)["Sex2"]
se_sex   <- summary(model)$coefficients["Sex2", "Std. Error"]
OR_sex   <- exp(beta_sex)
CI_sex   <- exp(beta_sex + c(-1, 1) * qnorm(0.975) * se_sex)
p_sex    <- summary(model)$coefficients["Sex2", "Pr(>|z|)"]
cat(sprintf("beta = %.4f\n", beta_sex))
cat(sprintf("OR = exp(%.4f) = %.4f\n", beta_sex, OR_sex))
cat(sprintf("95%% CI: (%.4f, %.4f)\n", CI_sex[1], CI_sex[2]))
cat(sprintf("p-value = %.4f\n", p_sex))
beta_sex <- coef(model)["Sex2"]; beta_sex
se_sex   <- summary(model)$coefficients["Sex2", "Std. Error"]; se_sex
OR_sex   <- exp(beta_sex); OR_sex
CI_sex   <- exp(beta_sex + c(-1, 1) * qnorm(0.975) * se_sex); CI_sex
p_sex    <- summary(model)$coefficients["Sex2", "Pr(>|z|)"]; p_sex
knitr::opts_chunk$set(echo = TRUE, message = FALSE, warning = FALSE)
knitr::opts_knit$set(root.dir = getwd())
beta_sex <- coef(model)["Sex2"]
se_sex   <- summary(model)$coefficients["Sex2", "Std. Error"]
OR_sex   <- exp(beta_sex)
CI_sex   <- exp(beta_sex + c(-1, 1) * qnorm(0.975) * se_sex)
p_sex    <- summary(model)$coefficients["Sex2", "Pr(>|z|)"]
cat(sprintf("beta = %.4f\n", beta_sex))
cat(sprintf("OR = exp(%.4f) = %.4f\n", beta_sex, OR_sex))
cat(sprintf("95%% CI: (%.4f, %.4f)\n", CI_sex[1], CI_sex[2]))
cat(sprintf("p-value = %.4f\n", p_sex))
cat(sprintf("Percent change in odds: (%.4f - 1) x 100 = %.1f%%\n", OR_sex, (OR_sex - 1) * 100))
beta_sex <- coef(model)["Sex2"]
se_sex   <- summary(model)$coefficients["Sex2", "Std. Error"]
OR_sex   <- exp(beta_sex)
CI_sex   <- exp(beta_sex + c(-1, 1) * qnorm(0.975) * se_sex)
p_sex    <- summary(model)$coefficients["Sex2", "Pr(>|z|)"]
cat(sprintf("beta = %.4f\n", beta_sex))
cat(sprintf("OR = exp(%.4f) = %.4f\n", beta_sex, OR_sex))
cat(sprintf("95%% CI: (%.4f, %.4f)\n", CI_sex[1], CI_sex[2]))
cat(sprintf("p-value = %.4f\n", p_sex))
cat(sprintf("Percent change in odds: (%.4f - 1) x 100 = %.1f%%\n", OR_sex, (OR_sex - 1) * 100))
beta_sex <- coef(model)["Sex2"]
OR_sex   <- exp(beta_sex)
cat(sprintf("beta = %.4f\n", beta_sex))
cat(sprintf("OR = exp(%.4f) = %.4f\n", beta_sex, OR_sex))
cat(sprintf("Percent change in odds: (%.4f - 1) x 100 = %.1f%%\n", OR_sex, (OR_sex - 1) * 100))
tennis_player <- data.frame(
Age      = 25,
Sex      = factor(2, levels = levels(tennis1_clean$Sex)),
Typ_curr = factor(1, levels = levels(tennis1_clean$Typ_curr)),
Wgt_curr = factor(2, levels = levels(tennis1_clean$Wgt_curr)),
Mat_curr = factor(4, levels = levels(tennis1_clean$Mat_curr)),
Str_curr = factor(1, levels = levels(tennis1_clean$Str_curr))
)
p_hat     <- predict(model, newdata = tennis_player, type = "response")
logit_hat <- predict(model, newdata = tennis_player, type = "link")
cat(sprintf("logit = %.4f\n", logit_hat))
cat(sprintf("P(tennis elbow) = %.4f (%.2f%%)\n", p_hat, p_hat * 100))
tennis_player <- data.frame(
Age      = 25,
Sex      = factor(2, levels = levels(tennis1_clean$Sex)),
Typ_curr = factor(1, levels = levels(tennis1_clean$Typ_curr)),
Wgt_curr = factor(2, levels = levels(tennis1_clean$Wgt_curr)),
Mat_curr = factor(4, levels = levels(tennis1_clean$Mat_curr)),
Str_curr = factor(1, levels = levels(tennis1_clean$Str_curr))
)
predict(model, newdata = tennis_player, type = "response")
